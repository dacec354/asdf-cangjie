#!/usr/bin/env bash
# asdf-cangjie: list-all
# Lists all available Cangjie SDK versions as a space-separated string.
# Primary source: the cangjie-version-manifest (LTS + STS channels, deduped).
# Falls back to git tags from cangjie_docs, then a static curated list.
# Output format: space-separated version strings to stdout, one line.

set -euo pipefail
IFS=$'\t\n'

MANIFEST_URL="${CANGJIE_MANIFEST_URL:-https://raw.githubusercontent.com/Zxilly/cangjie-version-manifest/refs/heads/master/versions.json}"

list_all_cangjie() {
  local versions

  # Try fetching the manifest first (most accurate)
  if command -v curl >/dev/null 2>&1 || command -v wget >/dev/null 2>&1; then
    versions="$(_list_from_manifest)"
  fi

  # Fall back to git tags from cangjie_docs
  if [ -z "$versions" ] && command -v git >/dev/null 2>&1; then
    versions="$(git ls-remote --tags --refs https://gitcode.com/Cangjie/cangjie_docs.git 2>/dev/null |
      sed 's|^.*refs/tags/v\{0,1\}||' |
      grep -vE '(alpha|beta|rc|\.alpha\.|\.beta\.|-alpha|-beta|-rc|bep|cjmp)' |
      grep -E '^[0-9]+\.[0-9]+\.[0-9]+' |
      sort -t. -k1,1n -k2,2n -k3,3n |
      tr '\n' ' ' |
      sed 's/ *$//' ||
      true)"
  fi

  # Final fallback
  if [ -z "$versions" ]; then
    versions="1.0.0 1.0.1 1.0.3 1.0.4 1.0.5 1.1.0 1.1.3"
  fi

  echo "$versions"
}

_list_from_manifest() {
  local manifest
  if command -v curl >/dev/null 2>&1; then
    manifest="$(curl -fsSL "$MANIFEST_URL" 2>/dev/null || true)"
  else
    manifest="$(wget -qO- "$MANIFEST_URL" 2>/dev/null || true)"
  fi

  if [ -z "$manifest" ]; then
    return 1
  fi

  # Extract all version keys from both LTS and STS, dedupe, sort
  if command -v jq >/dev/null 2>&1; then
    echo "$manifest" | jq -r '[.channels.lts.versions, .channels.sts.versions] | add | keys[]' 2>/dev/null |
      sort -t. -k1,1n -k2,2n -k3,3n |
      tr '\n' ' ' |
      sed 's/ *$//'
  else
    # Fallback: grep for version-like keys at the top level of versions objects
    echo "$manifest" | grep -oP '"[0-9]+\.[0-9]+\.[0-9]+(-[a-z]+\.[0-9]+)?"' |
      tr -d '"' |
      sort -t. -k1,1n -k2,2n -k3,3n |
      uniq |
      tr '\n' ' ' |
      sed 's/ *$//'
  fi
}

list_all_cangjie
