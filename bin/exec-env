#!/usr/bin/env bash
# asdf-cangjie: exec-env
# Injects CANGJIE_HOME, PATH, and LD_LIBRARY_PATH for asdf exec invocations.
# IMPORTANT: asdf v0.16+ sources this script (.) rather than eval-ing stdout.
# Use direct export statements, NOT echo "export ...".

# Platform detection — maps uname to Cangjie SDK directory naming.
local_os_name="linux"
case "$(uname -s)" in
    Linux)  local_os_name="linux" ;;
    Darwin) local_os_name="mac" ;;
esac

local_hw_arch="$(uname -m)"
: "${local_hw_arch:=x86_64}"

export CANGJIE_HOME="${ASDF_INSTALL_PATH}"
export PATH="${ASDF_INSTALL_PATH}/bin:${ASDF_INSTALL_PATH}/tools/bin${PATH:+:${PATH}}:${HOME}/.cjpm/bin"
export LD_LIBRARY_PATH="${ASDF_INSTALL_PATH}/runtime/lib/${local_os_name}_${local_hw_arch}_cjnative:${ASDF_INSTALL_PATH}/tools/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
