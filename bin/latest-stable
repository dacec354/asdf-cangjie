#!/usr/bin/env bash
# asdf-cangjie: latest-stable
# Returns the latest stable Cangjie SDK version.
# Primary source: the cangjie-version-manifest (STS channel "latest" field).
# Falls back to bin/list-all and picks the highest version.

set -euo pipefail
IFS=$'\t\n'

MANIFEST_URL="${CANGJIE_MANIFEST_URL:-https://raw.githubusercontent.com/Zxilly/cangjie-version-manifest/refs/heads/master/versions.json}"

latest_stable() {
  local script_dir
  script_dir="$(cd "$(dirname "$0")" && pwd)"

  # Try manifest first — the STS channel "latest" tracks the newest stable
  local version
  version="$(_latest_from_manifest)"
  if [ -n "$version" ]; then
    echo "$version"
    return 0
  fi

  # Fall back to list-all
  local versions
  versions="$("$script_dir/list-all" 2>/dev/null || true)"
  if [ -n "$versions" ]; then
    echo "$versions" | tr ' ' '\n' | tail -1
    return 0
  fi

  # Last resort
  echo "1.1.3"
}

_latest_from_manifest() {
  local manifest
  if command -v curl >/dev/null 2>&1; then
    manifest="$(curl -fsSL "$MANIFEST_URL" 2>/dev/null || true)"
  elif command -v wget >/dev/null 2>&1; then
    manifest="$(wget -qO- "$MANIFEST_URL" 2>/dev/null || true)"
  fi

  if [ -z "$manifest" ]; then
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    echo "$manifest" | jq -r '.channels.sts.latest // empty' 2>/dev/null || true
  else
    # Fallback: extract the "latest" value from the sts channel block
    echo "$manifest" | grep -A1 '"sts"' | grep '"latest"' |
      sed 's/.*"latest"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true
  fi
}

latest_stable
